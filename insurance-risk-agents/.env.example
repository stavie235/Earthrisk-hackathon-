# ================================================================
# EarthRisk — AI Agents environment variables
# Copy this file to .env and fill in your real values
# ================================================================

# IBM WatsonX Orchestrate
WO_DEVELOPER_EDITION_SOURCE=orchestrate
WO_INSTANCE=https://api.eu-central-1.dl.watson-orchestrate.ibm.com/instances/YOUR_INSTANCE_ID
WO_API_KEY=your_watsonx_mcsp_api_key_here

# Zilliz (Milvus cloud) — used by fetch_tools.py and ingest_milvus.py
ZILLIZ_URI=https://in03-xxxxxxxxxxxx.serverless.gcp-us-west1.cloud.zilliz.com
ZILLIZ_TOKEN=your_zilliz_api_token_here

# Express backend URL (only needed for fetch_building_history tool)
# Use ngrok when running locally: https://xxxx.ngrok-free.app
# Use the deployed URL in production
EARTHRISK_BACKEND_URL=http://localhost:9876

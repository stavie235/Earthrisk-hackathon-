# ================================================================
# EarthRisk — docker-compose environment variables
# Copy this file to .env and fill in the values
# ================================================================

# MySQL root password (used by db + backend)
DB_PASSWORD=change_me_to_any_password

# JWT signing secret for the Express API
JWT_SECRET=change_me_to_any_random_string

# Mapbox token for the React frontend map (baked in at build time)
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here

# IBM WatsonX Orchestrate (for AI agent chat in the backend)
WO_INSTANCE=https://api.eu-central-1.dl.watson-orchestrate.ibm.com/instances/your_instance_id
WO_API_KEY=your_watsonx_mcsp_api_key_here
